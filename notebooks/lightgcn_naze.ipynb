    {
      "cell_type": "code",
      "source": [
        "from sklearn.model_selection import train_test_split\n",
        "\n",
        "train, test = train_test_split(df, test_size=0.2, random_state=42)\n",
        "\n",
        "def build_edge_index(df, n_users):\n",
        "    users  = torch.tensor(df['user'].values, dtype=torch.long)\n",
        "    movies = torch.tensor(df['movie'].values + n_users, dtype=torch.long)\n",
        "    row = torch.cat([users, movies])\n",
        "    col = torch.cat([movies, users])\n",
        "    return torch.stack([row, col], dim=0)\n",
        "\n",
        "train_edge_index = build_edge_index(train, n_users)\n",
        "print(f\"Edge index shape: {train_edge_index.shape}\")\n",
        "# Expected: torch.Size([2, ~1600000])"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "c5w5W1pWzN0Q",
        "outputId": "25fa668a-78c6-45b3-b565-e566189f3148"
      },
      "execution_count": null,
      "outputs": [
